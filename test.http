POST {{baseUrl}}/api/brand
Content-Type: application/json

{ "name": "Fiat" }

### [3] Login avec l'utilisateur existant (moi@moi.fr)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "moi@moi.fr",
  "password": "moimoimoi"
}

> {%
  client.test("Login successful", function() {
    client.assert(response.status === 200, "Échec du login");
    client.global.set("auth_token", response.body.access_token);
    client.log("Token stocké : " + response.body.access_token);
  });
%}

### [4] Vérification de l'utilisateur courant
GET {{baseUrl}}/api/users/current
Authorization: Bearer {{auth_token}}

> {%
  client.test("User verification", function() {
    client.assert(response.status === 200, "Échec de récupération utilisateur");
    client.assert(response.body.email === "moi@moi.fr", "Mauvais utilisateur");
  });
%}

### [5] Création d'une voiture (pour obtenir le rôle Driver)
POST {{baseUrl}}/api/cars
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "model": "500",
  "registration": "XY-987-ZW",
  "fuel": "GASOLINE",
  "color": "Rouge",
  "firstRegistration": "2018-06-15",
  "brandId": 1,
  "ownerId": 2
}

> {%
  client.test("Car creation", function() {
    client.assert(response.status === 201, "Échec création voiture");
    client.global.set("car_id", response.body.id);
  });
%}

### [6] Vérification des rôles (doit inclure Driver maintenant)
GET {{baseUrl}}/api/users/current
Authorization: Bearer {{auth_token}}

> {%
  client.test("Role check", function() {
    client.assert(response.status === 200, "Statut devrait être 200");
    const roles = response.body.roles || [];
    const hasDriverRole = roles.some(role => role.label === "Driver");
    client.assert(hasDriverRole, "Rôle Driver manquant. Roles actuels: " + JSON.stringify(roles));
  });
%}

### [7] Liste des voitures de l'utilisateur
GET {{baseUrl}}/api/cars?userId=2
Authorization: Bearer {{auth_token}}

### [8] Suppression de la voiture de test (nettoyage)
DELETE {{baseUrl}}/api/cars/{{car_id}}?userId=2
Authorization: Bearer {{auth_token}}

### [9] Vérification finale
GET {{baseUrl}}/api/users/current
Authorization: Bearer {{auth_token}}

### [1] Test login avec debug avancé
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "jean.dupont@test.com",
  "password": "Test1234!"
}

> {%
  client.test("Login debug", function() {
    client.log("Status: " + response.status);
    client.log("Body: " + JSON.stringify(response.body));

    if (response.status === 401) {
      client.log("ÉCHEC : Vérifiez les logs du serveur");
      client.global.set("last_error", response.body);
    }
  });
%}

### [2] Vérification utilisateur (si login réussi)
GET {{baseUrl}}/api/users/current
Authorization: Bearer {{auth_token}}

> {%
  client.test("User check", function() {
    client.assert(response.status === 200, "Should return 200");
    client.log("User data: " + JSON.stringify(response.body));
  });
%}

### [B] Test login moi@moi.fr (fonctionnel)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{"email":"moi@moi.fr","password":"moimoimoi"}

> {%
  if (response.status === 200) {
    client.global.set("auth_token", response.body.access_token);
    client.log("Token moi@moi.fr: " + response.body.access_token);
  }
%}

### Créer zone de covoiturage depart
POST http://localhost:3000/api/carpool-zones
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "label": "Lyon Centre",
  "lat": 45.764043,
  "lng": 4.835659
}
### Créer zone de covoiturage arrivée
POST http://localhost:3000/api/carpool-zones
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "label": "Marseille Vieux Port",
  "lat": 43.296482,
  "lng": 5.36978
}

### Créer un trajet de covoiturage
POST http://localhost:3000/api/rides
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "departurePlace": "Lyon",
  "arrivalPlace": "Marseille",
  "departureDate": "2025-07-20",
  "arrivalDate": "2025-07-20",
  "departureTime": "08:00",
  "arrivalTime": "12:00",
  "carId": 1,
  "driverId": 2,
  "departureZoneId": 1,
  "arrivalZoneId": 2,
  "seats": 3,
  "price": 25,
  "status": "planned"
}

### Lister les trajets
GET http://localhost:3000/api/rides

### Rechercher des trajets (pas encore pret)
GET http://localhost:3000/api/rides/search?from=Lyon&to=Marseille&date=2025-07-20

### Supprimer un trajet (exemple avec ID = 3)
DELETE http://localhost:3000/api/rides/3
Authorization: Bearer {{auth_token}}

